<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Apps ki list dekhne ke liye (Android 11+ ke liye zaroori) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <!-- Voice search: speech recognition service dhoondhne ke liye -->
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <!-- Internet sirf AI feature (Groq) ke liye. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Voice search ke liye (user grant karega, optional feature) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Launcher "kabza" powers: -->
    <!-- Double-tap se screen lock (DevicePolicyManager ke liye nahi chahiye, accessibility-free way) -->
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR" />
    <!-- Recent apps / smart prediction ke liye (user grant karega) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_full"
        android:label="@string/app_name"
        android:theme="@style/Theme.Aura">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|screenLayout">

            <!-- Ye 2 lines Aura ko HOME SCREEN (launcher) banati hain -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Device Admin: double-tap se screen lock ke liye -->
        <receiver
            android:name=".AuraAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
